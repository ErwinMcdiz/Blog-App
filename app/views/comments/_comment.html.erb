<p>
  <strong><%= comment.commenter %></strong>: <%= comment.body %>
  <% if comment.persisted? %>
    <%= link_to "Show", article_comment_path(@article, comment) %>
    <%= link_to "Edit", edit_article_comment_path(@article, comment) %>
    <%= button_to "Delete", article_comment_path(@article, comment), 
                 method: :delete,
                 form: { data: { turbo_confirm: "Are you sure?" }, class: "d-inline" },
                 class: "btn btn-link p-0" %>
  <% end %>
</p>