<h1>Comment Details</h1>

<div class="comment">
  <p><strong>Commenter:</strong> <%= @comment.commenter %></p>
  <p><strong>Comment:</strong> <%= @comment.body %></p>
  <p><strong>Created at:</strong> <%= @comment.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
</div>

<div class="actions">
  <%= link_to "Edit", edit_article_comment_path(@article, @comment) %>
  
  <%= button_to "Delete", article_comment_path(@article, @comment), 
             method: :delete,
             form: { data: { turbo_confirm: "Warning: This will permanently delete this comment. Are you sure?" } },
             class: "btn btn-danger" %>
             
  <%= link_to "Back to Article", article_path(@article) %>
</div>